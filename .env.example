# DeVuelta
# Copia este archivo a `.env.local` para desarrollo local.

# Public base URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (cuando se conecte backend real)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Apple Wallet
